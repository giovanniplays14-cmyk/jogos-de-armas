        CreateSlider(moveScroll, "Fly Speed", 10, 500, Movement.FlySpeed, function(value)
            Movement.FlySpeed = value
        end, "Movement_FlySpeed")
        
        CreateToggle(moveScroll, "NoClip", Movement.NoClip, function(state)
            Movement.NoClip = state
        end, "Movement_NoClip")
        
        CreateToggle(moveScroll, "Infinite Jump", Movement.InfiniteJump, function(state)
            Movement.InfiniteJump = state
        end, "Movement_InfiniteJump")
        
        -- ==================== SETTINGS TAB ====================
        local settingsScroll = TabContents["Settings"]
        
        -- Save Config Button
        local saveBtn = Instance.new("TextButton")
        saveBtn.Size = UDim2.new(1, 0, 0, 40)
        saveBtn.Position = UDim2.new(0, 0, 0, 5)
        saveBtn.BackgroundColor3 = Colors.Accent
        saveBtn.BorderSizePixel = 0
        saveBtn.Text = "SAVE CONFIG"
        saveBtn.TextColor3 = Colors.Text
        saveBtn.TextSize = 14
        saveBtn.Font = Enum.Font.GothamBold
        saveBtn.Parent = settingsScroll
        
        CreateCorner(saveBtn, UDim.new(0, 6))
        
        saveBtn.MouseButton1Click:Connect(function()
            SaveCurrentConfig()
            saveBtn.Text = "SAVED!"
            wait(1)
            saveBtn.Text = "SAVE CONFIG"
        end)
        
        -- Reset Config Button
        local resetBtn = Instance.new("TextButton")
        resetBtn.Size = UDim2.new(1, 0, 0, 40)
        resetBtn.Position = UDim2.new(0, 0, 0, 55)
        resetBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        resetBtn.BorderSizePixel = 0
        resetBtn.Text = "RESET TO DEFAULT"
        resetBtn.TextColor3 = Colors.Text
        resetBtn.TextSize = 14
        resetBtn.Font = Enum.Font.GothamBold
        resetBtn.Parent = settingsScroll
        
        CreateCorner(resetBtn, UDim.new(0, 6))
        
        resetBtn.MouseButton1Click:Connect(function()
            SaveSystem:Reset()
            resetBtn.Text = "RESET! REJOIN TO APPLY"
            wait(2)
            resetBtn.Text = "RESET TO DEFAULT"
        end)
        
        -- Unload Button
        local unloadBtn = Instance.new("TextButton")
        unloadBtn.Size = UDim2.new(1, 0, 0, 40)
        unloadBtn.Position = UDim2.new(0, 0, 0, 105)
        unloadBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        unloadBtn.BorderSizePixel = 0
        unloadBtn.Text = "UNLOAD SCRIPT"
        unloadBtn.TextColor3 = Colors.Text
        unloadBtn.TextSize = 14
        unloadBtn.Font = Enum.Font.GothamBold
        unloadBtn.Parent = settingsScroll
        
        CreateCorner(unloadBtn, UDim.new(0, 6))
        
        unloadBtn.MouseButton1Click:Connect(function()
            Movement.Enabled = false
            ToggleFly(false)
            ScreenGui:Destroy()
            getgenv().ESPMokuroRunning = false
            if Connection then Connection:Disconnect() end
            if FOV_Circle then FOV_Circle:Remove() end
            for _, obj in pairs(ESPObjects) do
                for _, d in pairs(obj) do
                    if d then pcall(function() d:Remove() end) end
                end
            end
        end)
        
        -- Info
        local infoLabel = Instance.new("TextLabel")
        infoLabel.Size = UDim2.new(1, -20, 0, 200)
        infoLabel.Position = UDim2.new(0, 10, 0, 160)
        infoLabel.BackgroundTransparency = 1
        infoLabel.Text = "MOKURO HUB v3.0\n\nFeatures:\n- Team Check Fixed\n- Multi-Part Aim (Head/Body)\n- Speed & Jump Hack\n- Fly Mode\n- Config Save System\n\nKeys:\n[Insert] Hide/Show\n[F] Temporary Aim\n[Space] Jump (Infinite Jump)"
        infoLabel.TextColor3 = Colors.TextDark
        infoLabel.TextSize = 11
        infoLabel.Font = Enum.Font.Gotham
        infoLabel.TextWrapped = true
        infoLabel.TextYAlignment = Enum.TextYAlignment.Top
        infoLabel.Parent = settingsScroll
        
        -- ==================== DRAGGING ====================
        local dragging = false
        local dragStart = nil
        local startPos = nil
        
        TitleBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragStart = input.Position
                startPos = MainFrame.Position
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - dragStart
                MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        -- Insert key to toggle UI
        UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode == Enum.KeyCode.Insert then
                ScreenGui.Enabled = not ScreenGui.Enabled
            end
            
            -- Infinite Jump
            if Movement.InfiniteJump and input.KeyCode == Enum.KeyCode.Space then
                local char = LocalPlayer.Character
                if char then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                end
            end
        end)
        
        print("[Mokuro Hub] Interface created successfully!")
    end)
    
    if not success then
        warn("[Mokuro Hub] Error: " .. tostring(err))
    end
end

