-- Commands
local function SetupCommands()
    LocalPlayer.Chatted:Connect(function(msg)
        local cmd = msg:lower()

        if cmd == "/hopbr" or cmd == "/br" then
            ServerHop()
        elseif cmd == "/hoplow" or cmd == "/low" then
            ServerHopLowPlayers()
        elseif cmd == "/hop" then
            Config.OnlyBR = false
            ServerHop()
            Config.OnlyBR = true
        elseif cmd:sub(1, 5) == "/hop " then
            local region = cmd:sub(6)
            ServerHopRegion(region)
        end
    end)
end

