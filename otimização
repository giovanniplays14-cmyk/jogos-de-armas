-- Server Hop BR - Brazilian Servers Only
-- Place in any executor

local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Config
local Config = {
    MaxPlayers = 100,
    MinPlayers = 1,
    MaxPing = 300,
    OnlyBR = true,
    AutoRetry = true,
    RetryDelay = 3,
}

-- Brazilian region codes
local BRRegions = {
    "br", "brazil", "sa-east-1", "sa", "south-america",
}

-- Check if region is BR
local function IsBrazilian(region)
    if not region then return false end
    region = region:lower()
    for _, br in pairs(BRRegions) do
        if region:find(br) then
            return true
        end
    end
    return false
end

-- Get current place ID
local PlaceId = game.PlaceId
local JobId = game.JobId

-- Server list
local Servers = {}
local CurrentCursor = ""
local IsSearching = false

-- Fetch servers from Roblox API
local function FetchServers(cursor)
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. cursor
    end

    local success, result = pcall(function()
        return game:HttpGet(url)
    end)

    if success and result then
        local data = HttpService:JSONDecode(result)
        return data
    end
    return nil
end

-- Filter BR servers
local function FilterBRServers(serverList)
    local brServers = {}
    for _, server in pairs(serverList) do
        if server.id ~= JobId then
            local playerCount = server.playing or 0
            local maxPlayers = server.maxPlayers or 0
            local ping = server.ping or 0
            local region = server.region or ""

            -- Check player count
            if playerCount >= Config.MinPlayers and playerCount < maxPlayers then
                -- Check ping
                if ping <= Config.MaxPing then
                    -- Check BR region
                    if not Config.OnlyBR or IsBrazilian(region) then
                        table.insert(brServers, {
                            id = server.id,
                            players = playerCount,
                            maxPlayers = maxPlayers,
                            ping = ping,
                            region = region,
                            fps = server.fps or 0,
                        })
                    end
                end
            end
        end
    end
    return brServers
end

-- Get all BR servers
local function GetAllBRServers()
    Servers = {}
    CurrentCursor = ""
    IsSearching = true

    print("[ServerHop] Searching for BR servers...")

    local attempts = 0
    while attempts < 5 do
        local data = FetchServers(CurrentCursor)
        if not data then break end

        local filtered = FilterBRServers(data.data or {})
        for _, server in pairs(filtered) do
            table.insert(Servers, server)
        end

        CurrentCursor = data.nextPageCursor or ""
        if CurrentCursor == "" then break end

        attempts = attempts + 1
        wait(0.5)
    end

    IsSearching = false
    print("[ServerHop] Found " .. #Servers .. " BR servers")
    return Servers
end

-- Teleport to server
local function TeleportToServer(serverId)
    if not serverId then return false end

    print("[ServerHop] Teleporting to server: " .. serverId:sub(1, 8) .. "...")

    local success = pcall(function()
        TeleportService:TeleportToPlaceInstance(PlaceId, serverId, LocalPlayer)
    end)

    return success
end

-- Hop to random BR server
local function ServerHop()
    if IsSearching then
        print("[ServerHop] Already searching...")
        return
    end

    local servers = GetAllBRServers()

    if #servers == 0 then
        print("[ServerHop] No BR servers found!")
        if Config.AutoRetry then
            print("[ServerHop] Retrying in " .. Config.RetryDelay .. "s...")
            wait(Config.RetryDelay)
            return ServerHop()
        end
        return
    end

    -- Sort by lowest ping
    table.sort(servers, function(a, b)
        return a.ping < b.ping
    end)

    -- Try top 5 servers
    for i = 1, math.min(5, #servers) do
        local server = servers[i]
        print("[ServerHop] Trying server #" .. i .. " | Players: " .. server.players .. "/" .. server.maxPlayers .. " | Ping: " .. server.ping .. "ms | Region: " .. server.region)

        if TeleportToServer(server.id) then
            return
        end
        wait(1)
    end

    print("[ServerHop] Failed to join any server")
end

-- Hop to lowest player count server
local function ServerHopLowPlayers()
    if IsSearching then return end

    local servers = GetAllBRServers()

    if #servers == 0 then
        print("[ServerHop] No BR servers found!")
        return
    end

    -- Sort by lowest player count
    table.sort(servers, function(a, b)
        return a.players < b.players
    end)

    for i = 1, math.min(3, #servers) do
        local server = servers[i]
        print("[ServerHop] Low players server: " .. server.players .. "/" .. server.maxPlayers)
        if TeleportToServer(server.id) then
            return
        end
        wait(1)
    end
end

-- Hop to specific region
local function ServerHopRegion(regionCode)
    Config.OnlyBR = false
    local oldRegions = BRRegions
    BRRegions = {regionCode:lower()}

    ServerHop()

    BRRegions = oldRegions
    Config.OnlyBR = true
end

-- Auto hop when kicked
local function AutoRejoin()
    LocalPlayer.OnTeleport:Connect(function(state)
        if state == Enum.TeleportState.Failed then
            print("[ServerHop] Teleport failed, retrying...")
            wait(Config.RetryDelay)
            ServerHop()
        end
    end)
end

