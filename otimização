    for key, _ in pairs(Settings) do
        Settings[key] = false
        RemoveOptimization(key)
        if UIRefs[key] then
            UIRefs[key].Set(false)
        end
    end
    SaveCurrentConfig()
end)

-- Minimize/Maximize
local minimized = false
MinimizeBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, 320, 0, 50),
            Position = UDim2.new(0.5, -160, 0.5, -25)
        }):Play()
        MinimizeBtn.Text = "+"
        ScrollFrame.Visible = false
        OptimizeAllBtn.Visible = false
        DisableAllBtn.Visible = false
        SaveBtn.Visible = false
        ResetBtn.Visible = false
    else
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, 320, 0, 520),
            Position = UDim2.new(0.5, -160, 0.5, -260)
        }):Play()
        MinimizeBtn.Text = "-"
        wait(0.1)
        ScrollFrame.Visible = true
        OptimizeAllBtn.Visible = true
        DisableAllBtn.Visible = true
        SaveBtn.Visible = true
        ResetBtn.Visible = true
    end
end)

-- FPS Counter
RunService.RenderStepped:Connect(function()
    fpsCounter = fpsCounter + 1
    local current = tick()
    if current - lastTick >= 1 then
        FPSDisplay.Text = tostring(math.floor(fpsCounter))

        if fpsCounter >= 60 then
            FPSDisplay.TextColor3 = Color3.fromRGB(255, 255, 255)
        elseif fpsCounter >= 30 then
            FPSDisplay.TextColor3 = Color3.fromRGB(180, 180, 180)
        else
            FPSDisplay.TextColor3 = Color3.fromRGB(120, 120, 120)
        end

        fpsCounter = 0
        lastTick = current
    end
end)

-- Draggable
local dragging = false
local dragInput, dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

TitleBar.InputEnded:Connect(function()
    dragging = false
end)

-- Monitor new objects
Workspace.DescendantAdded:Connect(function(obj)
    if Settings.DisableShadows and obj:IsA("BasePart") then
        SafeCall(function()
            obj.CastShadow = false
        end)
    end
    if Settings.DisableParticles and (obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")) then
        SafeCall(function()
            obj.Enabled = false
        end)
    end
    if Settings.DisableDecals and (obj:IsA("Decal") or obj:IsA("Texture")) then
        SafeCall(function()
            obj.Transparency = 1
        end)
    end
end)

-- Monitor character
player.CharacterAdded:Connect(function(char)
    if Settings.DisableCharacterEffects then
        wait(1)
        for _, obj in pairs(char:GetDescendants()) do
            if obj:IsA("Trail") or obj:IsA("ParticleEmitter") or obj:IsA("Beam") then
                SafeCall(function()
                    obj.Enabled = false
                end)
            end
        end
    end
    if Settings.DisableAnimations then
        wait(1)
        SafeCall(function()
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
                    track:AdjustSpeed(0.5)
                end
            end
        end)
    end
end)

-- Keybind to toggle UI (Right Shift)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.RightShift then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

