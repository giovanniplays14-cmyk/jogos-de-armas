-- FPS Counter
RunService.RenderStepped:Connect(function()
    fpsCounter = fpsCounter + 1
    local current = tick()
    if current - lastTick >= 1 then
        FPSDisplay.Text = tostring(math.floor(fpsCounter))

        if fpsCounter >= 60 then
            FPSDisplay.TextColor3 = Color3.fromRGB(255, 255, 255)
        elseif fpsCounter >= 30 then
            FPSDisplay.TextColor3 = Color3.fromRGB(180, 180, 180)
        else
            FPSDisplay.TextColor3 = Color3.fromRGB(120, 120, 120)
        end

        fpsCounter = 0
        lastTick = current
    end
end)

