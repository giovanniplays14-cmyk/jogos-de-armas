-- Monitor new objects
Workspace.DescendantAdded:Connect(function(obj)
    if Settings.DisableShadows and obj:IsA("BasePart") then
        SafeCall(function()
            obj.CastShadow = false
        end)
    end
    if Settings.DisableParticles and (obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")) then
        SafeCall(function()
            obj.Enabled = false
        end)
    end
    if Settings.DisableDecals and (obj:IsA("Decal") or obj:IsA("Texture")) then
        SafeCall(function()
            obj.Transparency = 1
        end)
    end
end)

-- Monitor character
player.CharacterAdded:Connect(function(char)
    if Settings.DisableCharacterEffects then
        wait(1)
        for _, obj in pairs(char:GetDescendants()) do
            if obj:IsA("Trail") or obj:IsA("ParticleEmitter") or obj:IsA("Beam") then
                SafeCall(function()
                    obj.Enabled = false
                end)
            end
        end
    end
    if Settings.DisableAnimations then
        wait(1)
        SafeCall(function()
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
                    track:AdjustSpeed(0.5)
                end
            end
        end)
    end
end)

