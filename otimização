local function CreateToggle(name, settingKey, description)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Name = name
    ToggleFrame.Size = UDim2.new(1, 0, 0, 60)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    ToggleFrame.BorderSizePixel = 0
    ToggleFrame.Parent = ScrollFrame

    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 4)
    ToggleCorner.Parent = ToggleFrame

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color3.fromRGB(30, 30, 30)
    Stroke.Thickness = 1
    Stroke.Parent = ToggleFrame

    local Label = Instance.new("TextLabel")
    Label.Name = "Label"
    Label.Size = UDim2.new(1, -70, 0, 25)
    Label.Position = UDim2.new(0, 15, 0, 8)
    Label.BackgroundTransparency = 1
    Label.Text = name:upper()
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleFrame

    local Desc = Instance.new("TextLabel")
    Desc.Name = "Desc"
    Desc.Size = UDim2.new(1, -70, 0, 20)
    Desc.Position = UDim2.new(0, 15, 0, 33)
    Desc.BackgroundTransparency = 1
    Desc.Text = description
    Desc.TextColor3 = Color3.fromRGB(100, 100, 100)
    Desc.Font = Enum.Font.Gotham
    Desc.TextSize = 10
    Desc.TextXAlignment = Enum.TextXAlignment.Left
    Desc.Parent = ToggleFrame

    local Button = Instance.new("TextButton")
    Button.Name = "Button"
    Button.Size = UDim2.new(0, 44, 0, 24)
    Button.Position = UDim2.new(1, -59, 0.5, -12)
    Button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Button.BorderSizePixel = 0
    Button.Text = ""
    Button.AutoButtonColor = false
    Button.Parent = ToggleFrame

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(1, 0)
    ButtonCorner.Parent = Button

    local Indicator = Instance.new("Frame")
    Indicator.Name = "Indicator"
    Indicator.Size = UDim2.new(0, 18, 0, 18)
    Indicator.Position = UDim2.new(0, 3, 0.5, -9)
    Indicator.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    Indicator.BorderSizePixel = 0
    Indicator.Parent = Button

    local IndCorner = Instance.new("UICorner")
    IndCorner.CornerRadius = UDim.new(1, 0)
    IndCorner.Parent = Indicator

    local enabled = Settings[settingKey]

    local function UpdateVisual()
        if enabled then
            TweenService:Create(Button, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
            TweenService:Create(Indicator, TweenInfo.new(0.2), {
                Position = UDim2.new(1, -21, 0.5, -9),
                BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            }):Play()
            ToggleFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Stroke.Color = Color3.fromRGB(60, 60, 60)
        else
            TweenService:Create(Button, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            }):Play()
            TweenService:Create(Indicator, TweenInfo.new(0.2), {
                Position = UDim2.new(0, 3, 0.5, -9),
                BackgroundColor3 = Color3.fromRGB(80, 80, 80)
            }):Play()
            ToggleFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            Stroke.Color = Color3.fromRGB(30, 30, 30)
        end
    end

    -- Apply visual on load
    if enabled then
        Button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Indicator.Position = UDim2.new(1, -21, 0.5, -9)
        Indicator.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        ToggleFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        Stroke.Color = Color3.fromRGB(60, 60, 60)
    end

    Button.MouseButton1Click:Connect(function()
        enabled = not enabled
        Settings[settingKey] = enabled
        UpdateVisual()
        SaveCurrentConfig()

        if enabled then
            ApplyOptimization(settingKey)
        else
            RemoveOptimization(settingKey)
        end
    end)

    ToggleFrame.MouseEnter:Connect(function()
        if not enabled then
            TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            }):Play()
        end
    end)

    ToggleFrame.MouseLeave:Connect(function()
        if not enabled then
            TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            }):Play()
        end
    end)

    -- Store reference
    UIRefs[settingKey] = {
        Set = function(state)
            enabled = state
            Settings[settingKey] = state
            UpdateVisual()
            if state then
                ApplyOptimization(settingKey)
            else
                RemoveOptimization(settingKey)
            end
        end
    }

    return ToggleFrame
end

