-- FPS Counter
RunService.RenderStepped:Connect(function()
    fpsCounter = fpsCounter + 1
    local current = tick()
    if current - lastTick >= 1 then
        FPSDisplay.Text = tostring(math.floor(fpsCounter))
        
        if fpsCounter >= 60 then
            FPSDisplay.TextColor3 = Color3.fromRGB(255, 255, 255)
        elseif fpsCounter >= 30 then
            FPSDisplay.TextColor3 = Color3.fromRGB(180, 180, 180)
        else
            FPSDisplay.TextColor3 = Color3.fromRGB(120, 120, 120)
        end
        
        fpsCounter = 0
        lastTick = current
    end
end)

-- Draggable
local dragging = false
local dragInput, dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

TitleBar.InputEnded:Connect(function()
    dragging = false
end)

-- Monitor new objects
table.insert(connections, Workspace.DescendantAdded:Connect(function(obj)
    if Settings.DisableShadows and obj:IsA("BasePart") then
        SafeCall(function()
            obj.CastShadow = false
        end)
    end
    if Settings.DisableParticles and (obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")) then
        SafeCall(function()
            obj.Enabled = false
        end)
    end
    if Settings.DisableDecals and (obj:IsA("Decal") or obj:IsA("Texture")) then
        SafeCall(function()
            obj.Transparency = 1
        end)
    end
end))

-- Monitor character
