function SaveSystem:Load()
    local success, result = pcall(function()
        if readfile then
            local data = readfile(self.ConfigName .. ".json")
            return HttpService:JSONDecode(data)
        end
        return nil
    end)

    if success and result then
        print("[SaveSystem] Config loaded")
        return result
    else
        print("[SaveSystem] Using default config")
        return self.DefaultConfig
    end
end

function SaveSystem:Save(config)
    pcall(function()
        if writefile then
            writefile(self.ConfigName .. ".json", HttpService:JSONEncode(config))
            print("[SaveSystem] Config saved")
        end
    end)
end

function SaveSystem:Reset()
    pcall(function()
        if delfile then
            delfile(self.ConfigName .. ".json")
        end
    end)
    print("[SaveSystem] Config reset")
    return self.DefaultConfig
end

