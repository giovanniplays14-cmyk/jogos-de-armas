        wait(1)
        for _, obj in pairs(char:GetDescendants()) do
            if obj:IsA("Trail") or obj:IsA("ParticleEmitter") or obj:IsA("Beam") then
                SafeCall(function()
                    obj.Enabled = false
                end)
            end
        end
    end
end))

