-- OPTIMIZATION FUNCTIONS

function ApplyOptimization(key)
    SafeCall(function()
        if key == "ReduceGraphics" then
            SafeCall(function()
                local UserSettings = UserSettings()
                local GameSettings = UserSettings.GameSettings
                GameSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
            end)
            SafeCall(function()
                settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            end)

        elseif key == "DisableShadows" then
            Lighting.GlobalShadows = false
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") then
                    if originalStates[obj] == nil then
                        originalStates[obj] = obj.CastShadow
                    end
                    obj.CastShadow = false
                end
            end

        elseif key == "ReduceRenderDistance" then
            local camera = Workspace.CurrentCamera
            if camera then
                camera.FieldOfView = 70
            end

        elseif key == "DisableParticles" then
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
                    if originalStates[obj] == nil then
                        originalStates[obj] = obj.Enabled
                    end
                    obj.Enabled = false
                end
            end

        elseif key == "OptimizeLighting" then
            originalLightingTech = Lighting.Technology
            originalFogStart = Lighting.FogStart
            originalFogEnd = Lighting.FogEnd
            SafeCall(function()
                Lighting.Technology = Enum.Technology.Compatibility
            end)
            SafeCall(function()
                Lighting.FogEnd = 500
                Lighting.FogStart = 0
            end)

        elseif key == "DisableBloom" then
            for _, effect in pairs(Lighting:GetChildren()) do
                if effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or effect:IsA("ColorCorrectionEffect") or effect:IsA("DepthOfFieldEffect") then
                    if originalStates[effect] == nil then
                        originalStates[effect] = effect.Enabled
                    end
                    effect.Enabled = false
                end
            end

        elseif key == "ReduceTextureQuality" then
            SafeCall(function()
                originalTextureQuality = settings().Rendering.TextureQuality
                settings().Rendering.TextureQuality = Enum.TextureQuality.Low
            end)

        elseif key == "DisableDecals" then
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("Decal") or obj:IsA("Texture") then
                    if originalStates[obj] == nil then
                        originalStates[obj] = obj.Transparency
                    end
                    obj.Transparency = 1
                end
            end

        elseif key == "LowQualityParts" then
            SafeCall(function()
                originalMeshDetail = settings().Rendering.MeshPartDetailLevel
                settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04
            end)

        elseif key == "DisableCharacterEffects" then
            SafeCall(function()
                local character = player.Character
                if character then
                    for _, obj in pairs(character:GetDescendants()) do
                        if obj:IsA("Trail") or obj:IsA("ParticleEmitter") or obj:IsA("Beam") then
                            if originalStates[obj] == nil then
                                originalStates[obj] = obj.Enabled
                            end
                            obj.Enabled = false
                        end
                    end
                end
            end)

        elseif key == "OptimizeWorkspace" then
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") then
                    if obj.Transparency >= 1 and obj.CanCollide == false then
                        if originalStates[obj] == nil then
                            originalStates[obj] = obj.Parent
                        end
                        obj.Parent = nil
                    end
                end
            end

        elseif key == "DisableAnimations" then
            SafeCall(function()
                local character = player.Character
                if character then
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
                            track:AdjustSpeed(0.5)
                        end
                    end
                end
            end)

        elseif key == "ReduceSound" then
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("Sound") then
                    if originalStates[obj] == nil then
                        originalStates[obj] = obj.Volume
                    end
                    obj.Volume = 0
                end
            end

        elseif key == "OptimizeCamera" then
            local camera = Workspace.CurrentCamera
            if camera then
                SafeCall(function()
                    camera.FieldOfView = 70
                end)
            end
        end
    end)
end

function RemoveOptimization(key)
    SafeCall(function()
        if key == "ReduceGraphics" then
            SafeCall(function()
                local UserSettings = UserSettings()
                local GameSettings = UserSettings.GameSettings
                GameSettings.SavedQualityLevel = Enum.SavedQualitySetting.Automatic
            end)
            SafeCall(function()
                settings().Rendering.QualityLevel = Enum.QualityLevel.Level10
            end)

        elseif key == "DisableShadows" then
            Lighting.GlobalShadows = true
            for obj, state in pairs(originalStates) do
                if typeof(obj) == "Instance" and obj:IsA("BasePart") then
                    obj.CastShadow = state
                    originalStates[obj] = nil
                end
            end

        elseif key == "ReduceRenderDistance" then
            local camera = Workspace.CurrentCamera
            if camera then
                camera.FieldOfView = 70
            end

        elseif key == "DisableParticles" then
            for obj, state in pairs(originalStates) do
                if typeof(obj) == "Instance" and (obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")) then
                    obj.Enabled = state
                    originalStates[obj] = nil
                end
            end

        elseif key == "OptimizeLighting" then
            if originalLightingTech then
                SafeCall(function()
                    Lighting.Technology = originalLightingTech
                end)
                originalLightingTech = nil
            end
            if originalFogEnd then
                SafeCall(function()
                    Lighting.FogEnd = originalFogEnd
                    Lighting.FogStart = originalFogStart
                end)
                originalFogEnd = nil
                originalFogStart = nil
            end

        elseif key == "DisableBloom" then
            for obj, state in pairs(originalStates) do
                if typeof(obj) == "Instance" and (obj:IsA("BloomEffect") or obj:IsA("BlurEffect") or obj:IsA("SunRaysEffect") or obj:IsA("ColorCorrectionEffect") or obj:IsA("DepthOfFieldEffect")) then
                    obj.Enabled = state
                    originalStates[obj] = nil
                end
            end

        elseif key == "ReduceTextureQuality" then
            if originalTextureQuality then
                SafeCall(function()
                    settings().Rendering.TextureQuality = originalTextureQuality
                end)
                originalTextureQuality = nil
            end

        elseif key == "DisableDecals" then
            for obj, state in pairs(originalStates) do
                if typeof(obj) == "Instance" and (obj:IsA("Decal") or obj:IsA("Texture")) then
                    obj.Transparency = state
                    originalStates[obj] = nil
                end
            end

        elseif key == "LowQualityParts" then
            if originalMeshDetail then
                SafeCall(function()
                    settings().Rendering.MeshPartDetailLevel = originalMeshDetail
                end)
                originalMeshDetail = nil
            end

        elseif key == "DisableCharacterEffects" then
            SafeCall(function()
                local character = player.Character
                if character then
                    for obj, state in pairs(originalStates) do
                        if typeof(obj) == "Instance" and (obj:IsA("Trail") or obj:IsA("ParticleEmitter") or obj:IsA("Beam")) then
                            obj.Enabled = state
                            originalStates[obj] = nil
                        end
                    end
                end
            end)

        elseif key == "OptimizeWorkspace" then
            for obj, parent in pairs(originalStates) do
                if typeof(obj) == "Instance" and obj:IsA("BasePart") and parent then
                    obj.Parent = parent
                    originalStates[obj] = nil
                end
            end

        elseif key == "DisableAnimations" then
            SafeCall(function()
                local character = player.Character
                if character then
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
                            track:AdjustSpeed(1)
                        end
                    end
                end
            end)

        elseif key == "ReduceSound" then
            for obj, state in pairs(originalStates) do
                if typeof(obj) == "Instance" and obj:IsA("Sound") then
                    obj.Volume = state
                    originalStates[obj] = nil
                end
            end

        elseif key == "OptimizeCamera" then
            local camera = Workspace.CurrentCamera
            if camera then
                SafeCall(function()
                    camera.FieldOfView = 70
                end)
            end
        end
    end)
end

-- Apply saved settings on load
for key, value in pairs(Settings) do
    if value then
        ApplyOptimization(key)
    end
end

