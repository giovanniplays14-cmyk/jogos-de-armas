    TabBtn.Size = UDim2.new(0, 120, 1, 0)
    TabBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    TabBtn.BorderSizePixel = 0
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(120, 120, 120)
    TabBtn.Font = Enum.Font.GothamBold
    TabBtn.TextSize = 12
    TabBtn.AutoButtonColor = false
    TabBtn.Parent = TabBar

    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 4)
    TabCorner.Parent = TabBtn

    local TabContent = Instance.new("Frame")
    TabContent.Name = name .. "Content"
    TabContent.Size = UDim2.new(1, 0, 1, 0)
    TabContent.BackgroundTransparency = 1
    TabContent.BorderSizePixel = 0
    TabContent.Visible = false
    TabContent.Parent = ContentContainer

    Tabs[name] = {
        Button = TabBtn,
        Content = TabContent,
        Active = false
    }

    TabBtn.MouseButton1Click:Connect(function()
        for tabName, tabData in pairs(Tabs) do
            tabData.Active = false
            tabData.Content.Visible = false
            TweenService:Create(tabData.Button, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(15, 15, 15),
                TextColor3 = Color3.fromRGB(120, 120, 120)
            }):Play()
        end

        Tabs[name].Active = true
        Tabs[name].Content.Visible = true
        TweenService:Create(TabBtn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()

        CurrentTab = name
    end)

    return TabContent
end

